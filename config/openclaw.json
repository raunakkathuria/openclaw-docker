// OpenClaw Agent Configuration
// JSON5 syntax is supported (comments, trailing commas).
{
  gateway: {
    // CRITICAL for self-hosted/container deployments.
    mode: "local",

    // "lan" makes the gateway accept connections arriving via port forwarding
    // (not just its own loopback). Required for Docker/Podman to reach it.
    // Valid values: loopback | lan | tailnet | custom | auto
    bind: "lan",

    // Required when bind != "loopback". OpenClaw enforces an origin allowlist
    // for the Control UI when listening on non-loopback interfaces.
    // Add every origin you'll open in a browser.
    controlUi: {
      allowedOrigins: [
        "http://127.0.0.1:18789",
        "http://localhost:18789",
      ],
      // Simpler alternative — uses the HTTP Host header as the allowed origin.
      // Uncomment this and remove allowedOrigins if you keep hitting origin errors:
      dangerouslyAllowHostHeaderOriginFallback: true,
    },
  },

  // Agent sandbox: each agent's tool calls run in their own isolated container.
  agents: {
    defaults: {
      sandbox: {
        mode: "non-main",   // off | non-main | all
        scope: "agent",     // session | agent | shared
        readOnlyRoot: true,
        network: "none",
        capDrop: ["ALL"],
        memory: "1g",
        pids: 256,
      },
    },
  },

  skills: {
    // "clawhub": {},
    // "mcporter": {},
  },
}
