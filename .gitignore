data/config/openclaw.json
data/workspace/
data/canvas/
data/identity/
data/sessions/
data/agents/
data/logs/
data/tmp/
# Runtime config store — written by 'config set' and updated on every gateway
# start (lastTouchedAt). Not committed; setup.sh re-applies settings on first run.
data/openclaw.json
# Auto-generated update-check cache
data/update-check.json
# Legacy individual mounts (replaced by data/)
workspace/
canvas/
*.log
