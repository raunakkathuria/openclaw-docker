// OpenClaw gateway + agent configuration (JSON5)
{
  gateway: {
    // Required for self-hosted deployments — without this OpenClaw
    // tries to connect to the remote Claude.ai gateway and won't start.
    mode: "local",

    // "lan" accepts connections arriving via Docker port forwarding.
    bind: "lan",

    // Required when bind != "loopback": explicit origin allowlist for the
    // Control UI. Add any host:port you open in a browser.
    controlUi: {
      dangerouslyAllowHostHeaderOriginFallback: true,
    },

    // NOTE: gateway.trustedProxies cannot be set here — it must be written
    // to the runtime config store via:
    //   node openclaw.mjs config set gateway.trustedProxies '["127.0.0.1","::1"]'
    // setup.sh does this automatically on first run.
  },

  // Each agent's tool calls (shell, file I/O) run inside their own
  // short-lived isolated container — no shared state between agents.
  agents: {
    defaults: {
      sandbox: {
        mode: "non-main",  // off | non-main | all
        scope: "agent",    // session | agent | shared
        readOnlyRoot: true,
        network: "none",
        capDrop: ["ALL"],
        memory: "1g",
        pids: 256,
      },
    },
  },

  skills: {
    // "clawhub": {},
    // "mcporter": {},
  },

  // ── Channels (optional) ────────────────────────────────────────────────────
  // Uncomment and fill in to connect agents to messaging platforms.
  // ⚠️  This file (openclaw.json) is gitignored — secrets stay local.
  //     Copy openclaw.json.example → openclaw.json, never edit the example
  //     directly with real tokens.

  // channels: {
  //   telegram: {
  //     enabled: true,
  //     botToken: "123456789:ABCDef...",  // from @BotFather — keep secret
  //
  //     // DM access control:
  //     //   "allowlist" — only listed numeric user IDs (get yours from @userinfobot)
  //     //   "pairing"   — approve via web UI (safer default for shared gateways)
  //     //   "open"      — anyone (not recommended)
  //     dmPolicy: "allowlist",
  //     allowFrom: ["YOUR_TELEGRAM_USER_ID"],
  //
  //     // Group chats (bot only replies when @-mentioned by default)
  //     groupPolicy: "allowlist",
  //     groups: {
  //       "*": { requireMention: true },
  //     },
  //
  //     streaming: "partial",   // show reply chunks as they arrive
  //     ackReaction: "👀",      // reaction while processing
  //   },
  // },
}
