# ─────────────────────────────────────────────────────────────────
# OpenClaw Docker Environment Configuration
# Copy this file: cp .env.example .env
# Then fill in the required values below.
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────

# Your Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-...

# Gateway authentication token — generate with:
#   openssl rand -hex 32
# The setup.sh script generates this automatically.
OPENCLAW_GATEWAY_TOKEN=

# ── Image ─────────────────────────────────────────────────────────

# Use the official pre-built image (recommended)
# or replace with a locally built tag: openclaw:local
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ── Ports ─────────────────────────────────────────────────────────

# Gateway WebSocket endpoint + API
OPENCLAW_PORT=18789

# Bridge channel (for desktop pairing)
OPENCLAW_BRIDGE_PORT=18790

# HTTP browser control UI (canvas, agent browser tools)
OPENCLAW_BROWSER_PORT=18791

# Browserless port (only used if you enable the browserless profile)
BROWSERLESS_PORT=3000

# ── Sandbox ───────────────────────────────────────────────────────

# Enable agent sandbox isolation (1 = on, 0 = off)
# With sandbox on, each agent's tool execution runs in its own
# isolated Docker container — strongly recommended.
OPENCLAW_SANDBOX=1

# Path to the container socket (setup.sh auto-detects this for Podman).
# Docker Desktop (Linux default):
DOCKER_SOCKET=/var/run/docker.sock
# Docker Desktop for Mac — try one of:
# DOCKER_SOCKET=/Users/<you>/.docker/run/docker.sock
# Podman on macOS (Homebrew) — setup.sh finds this automatically, but you can pin it:
# DOCKER_SOCKET=/Users/<you>/.local/share/containers/podman/machine/podman.sock
# Podman on Linux (rootless):
# DOCKER_SOCKET=/run/user/1000/podman/podman.sock

# ── Network ───────────────────────────────────────────────────────

# How the gateway binds its listener:
#   lan      — reachable from host browser via 127.0.0.1 (default)
#   loopback — only reachable from inside the container
#   tailnet  — expose via Tailscale (requires Tailscale sidecar)
OPENCLAW_GATEWAY_BIND=lan

# ── Optional ──────────────────────────────────────────────────────

# Timezone (used for cron scheduling, logs)
TZ=UTC

# Browserless access token (leave empty to disable auth)
BROWSERLESS_TOKEN=

# Additional apt packages to install into the image at startup
# OPENCLAW_DOCKER_APT_PACKAGES=ffmpeg jq

# Extra bind mounts (colon-separated list of host:container paths)
# OPENCLAW_EXTRA_MOUNTS=/data/shared:/mnt/shared

# Persist the entire /home/node directory in a Docker volume
# instead of bind-mounting only config/ and workspace/
# OPENCLAW_HOME_VOLUME=openclaw-home
