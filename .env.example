# OpenClaw environment configuration
# cp .env.example .env  →  fill in values  →  docker compose up -d
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ── Image ─────────────────────────────────────────────────────────────────────
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ── Ports (host-side) ─────────────────────────────────────────────────────────
OPENCLAW_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_BROWSER_PORT=18791
OPENCLAW_RELAY_PORT=18792

# Host bind address for all ports.
# Docker: 127.0.0.1 (local-only, default)
# Podman on macOS: 0.0.0.0 (pasta networking can't forward loopback-only bindings)
# setup.sh sets this automatically when Podman + macOS is detected.
# OPENCLAW_BIND=127.0.0.1

# ── Sandbox ───────────────────────────────────────────────────────────────────
OPENCLAW_SANDBOX=1

# Docker socket — change if using Docker Desktop on Mac:
# DOCKER_SOCKET=/Users/<you>/.docker/run/docker.sock
DOCKER_SOCKET=/var/run/docker.sock

# ── Optional ──────────────────────────────────────────────────────────────────
TZ=UTC
BROWSERLESS_TOKEN=
